---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---

{faqs.length > 0 && (
  <section class="faq-block" aria-labelledby="faq-title">
    <h2 id="faq-title">常见问题</h2>
    {faqs.map((faq) => (
      <details>
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </section>
)}
