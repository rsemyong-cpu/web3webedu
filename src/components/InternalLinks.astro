---
interface RelatedItem {
  title: string;
  url: string;
}

interface Props {
  links: RelatedItem[];
  locale?: "zh-CN" | "en";
}

const { links, locale = "zh-CN" } = Astro.props;
const ariaLabel = locale === "en" ? "Topic links" : "主题内链";
const heading = locale === "en" ? "Topic Links" : "主题路径";
---

{links.length > 0 && (
  <nav class="internal-links" aria-label={ariaLabel}>
    <strong>{heading}</strong>
    {links.slice(0, 8).map((item) => <a href={item.url}>{item.title}</a>)}
  </nav>
)}
