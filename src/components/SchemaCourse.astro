---
import SchemaJsonLd from "./SchemaJsonLd.astro";
import { absoluteUrl, SITE } from "@/lib/site";

interface Props {
  title: string;
  description: string;
  path: string;
}

const { title, description, path } = Astro.props;
const data = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: title,
  description,
  url: absoluteUrl(path, Astro.site),
  provider: {
    "@type": "Organization",
    name: SITE.name,
    sameAs: absoluteUrl("/", Astro.site)
  }
};
---

<SchemaJsonLd data={data} />
