---
import SchemaJsonLd from "./SchemaJsonLd.astro";
import { SITE, absoluteUrl } from "@/lib/site";

const data = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  alternateName: SITE.zhName,
  url: absoluteUrl("/", Astro.site),
  description: SITE.description,
  logo: absoluteUrl("/favicon.svg", Astro.site)
};
---

<SchemaJsonLd data={data} />
