---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3).slice(0, 12);
---

{toc.length > 0 && (
  <nav class="toc" aria-label="目录">
    <strong>目录</strong>
    {toc.map((heading) => (
      <a href={`#${heading.slug}`} style={`padding-left:${heading.depth === 3 ? "0.9rem" : "0"}`}>
        {heading.text}
      </a>
    ))}
  </nav>
)}
