---
import { getCollection, render } from "astro:content";
import CourseLayout from "@/layouts/CourseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("courses", ({ data }) => data.index !== false);
  return entries.map((entry) => ({ params: { slug: entry.data.slug ?? entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<CourseLayout entry={entry} headings={headings}>
  <Content />
</CourseLayout>
