---
import { getCollection, render } from "astro:content";
import ResearchLayout from "@/layouts/ResearchLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("research", ({ data }) => data.index !== false);
  return entries.map((entry) => ({ params: { slug: entry.data.slug ?? entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ResearchLayout entry={entry} headings={headings}>
  <Content />
</ResearchLayout>
