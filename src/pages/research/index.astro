---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CollectionIndex from "@/components/CollectionIndex.astro";
import { getSectionEntries } from "@/lib/content";
const entries = await getSectionEntries("research");
---

<BaseLayout title="研究中心" description="研究 USDT 与域名支付、隐私域名注册、Web3域名身份、稳定币经济、DNS安全与域名治理。" path="/research/">
  <CollectionIndex title="研究中心" description="每个研究方向都有核心问题、入门阅读、深度报告、案例研究、数据观察、FAQ 与相关术语。" entries={entries} eyebrow="Research" />
</BaseLayout>
